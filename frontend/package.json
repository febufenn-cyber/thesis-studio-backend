    "typecheck": "tsc --noEmit",
    "dev": "vite build --watch"
  },
  "dependencies": {
    "@tanstack/react-query": "5.51.23",
    "dompurify": "3.1.6",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "6.26.1"
  },
  "devDependencies": {
    "@types/dompurify": "3.0.5",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "@vitejs/plugin-react": "4.3.1",
    "typescript": "5.5.4",
    "vite": "5.4.2"
  }
}
