# Robofox Thesis Studio — production environment example
# Store the real file outside Git. Inject secrets through the protected deployment
# environment or mounted secret files. Replace every CHANGE_ME value.

# ===== Application / immutable release identity =====
ENV=production
DEBUG=false
LOG_LEVEL=INFO
RELEASE_SHA=CHANGE_ME_EXACT_MAIN_COMMIT_SHA
BUILD_TIME=CHANGE_ME_RFC3339_BUILD_TIME
SCHEMA_VERSION=0018
RENDERER_VERSION=phase1-renderer
PROMPT_BUNDLE_VERSION=phase3-prompts
CANONICAL_SCHEMA_VERSION=1

# ===== Isolated PostgreSQL =====
# Production validation rejects localhost/postgres/db hosts. Use the managed or
# otherwise isolated database endpoint with provider-enforced TLS.
DATABASE_URL=postgresql+asyncpg://thesis:CHANGE_ME@managed-db.internal:5432/thesis_studio?ssl=require

# ===== Authentication / revocable sessions =====
JWT_SECRET=CHANGE_ME_RUN_OPENSSL_RAND_HEX_32
JWT_ALGORITHM=HS256
JWT_EXPIRY_DAYS=30
MAGIC_LINK_EXPIRY_MINUTES=15
SESSION_IDLE_MINUTES=720
SESSION_ABSOLUTE_DAYS=30
SESSION_REAUTH_MINUTES=15
SESSION_COOKIE_NAME=access_token
DEFAULT_INSTITUTION_SHORT_NAME=CHANGE_ME
GOOGLE_CLIENT_ID=

# ===== Frontend / CORS =====
FRONTEND_URL=https://thesis.robofox.online
FRONTEND_LOGIN_PATH=/auth/verify
CORS_ORIGINS=https://thesis.robofox.online

# ===== AI =====
# Keep AI disabled until a governed commercial provider route, credentials,
# concurrency limits and provider-health checks are configured. The shared local
# CLI adapter remains pilot-only.
ANTHROPIC_API_KEY=CHANGE_ME_PROVIDER_KEY_OR_MIGRATION_PLACEHOLDER
CLAUDE_CLI_PATH=claude
CLAUDE_COACHING_MODEL=claude-sonnet-4-6
CLAUDE_COMPILE_MODEL=claude-opus-4-8
CLAUDE_UTILITY_MODEL=claude-haiku-4-5-20251001
AI_GLOBAL_ENABLED=false
AI_COMMERCIAL_PROVIDER_READY=false
AI_PROVIDER_FAILURE_THRESHOLD=5
AI_CIRCUIT_COOLDOWN_SECONDS=300
AI_GLOBAL_EMERGENCY_THROTTLE=false
USER_MONTHLY_INPUT_TOKEN_CAP=2000000
USER_MONTHLY_OUTPUT_TOKEN_CAP=200000

# ===== Durable worker queues =====
JOB_LEASE_SECONDS=120
JOB_HEARTBEAT_SECONDS=20

# ===== Billing =====
# Manual billing is a supported pilot state and is reported as a readiness warning.
# A non-manual provider additionally requires a strong BILLING_WEBHOOK_SECRET.
BILLING_PROVIDER=manual
BILLING_WEBHOOK_SECRET=
BILLING_WEBHOOK_TOLERANCE_SECONDS=300
BILLING_GRACE_DAYS=7

# ===== Email =====
RESEND_API_KEY=CHANGE_ME
EMAIL_FROM_ADDRESS=thesis@robofox.online
EMAIL_FROM_NAME=Robofox Thesis Studio

# ===== Cloudflare R2 durable object storage =====
STORAGE_BACKEND=r2
PRODUCTION_REQUIRE_R2=true
LOCAL_STORAGE_DIR=/app/var/storage
R2_ACCOUNT_ID=CHANGE_ME
R2_ACCESS_KEY_ID=CHANGE_ME
R2_SECRET_ACCESS_KEY=CHANGE_ME
R2_BUCKET_NAME=thesis-studio
R2_PUBLIC_URL=

# ===== Untrusted-upload malware scanning =====
MALWARE_SCAN_MODE=clamav
PRODUCTION_REQUIRE_MALWARE_SCAN=true
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_SECONDS=30

# ===== Privacy / support =====
SUPPORT_ACCESS_DEFAULT_MINUTES=60
DELETION_GRACE_DAYS=30
PRIVACY_HASH_PEPPER=CHANGE_ME_INDEPENDENT_RANDOM_SECRET

# ===== Release evidence =====
# Mounted read-only by deploy/compose.phase5.yml. The file must contain current,
# human-reviewed backup evidence; configuration alone does not prove recoverability.
BACKUP_EVIDENCE_PATH=/run/secrets/latest-backup-evidence.json

# ===== Compose interpolation values =====
# These are normally exported by the release workflow rather than kept in env_file.
# ROBOFOX_IMAGE=ghcr.io/febufenn-cyber/thesis-studio-backend@sha256:CHANGE_ME
# CLAMAV_IMAGE=clamav/clamav@sha256:CHANGE_ME
# BACKUP_EVIDENCE_HOST_PATH=/secure/path/latest-backup-evidence.json
