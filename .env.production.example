# === Production .env for thesis.robofox.online ===
# Copy to /opt/thesis-studio-backend/.env on the VM.
# Replace all CHANGE_ME values. NEVER commit .env.

ENV=production
DEBUG=false
LOG_LEVEL=INFO

DATABASE_URL=postgresql+asyncpg://thesis:CHANGE_ME@localhost:5432/thesis_studio

JWT_SECRET=CHANGE_ME_RUN_OPENSSL_RAND_HEX_32
JWT_ALGORITHM=HS256
JWT_EXPIRY_DAYS=30
MAGIC_LINK_EXPIRY_MINUTES=15

FRONTEND_URL=https://thesis.robofox.online
FRONTEND_LOGIN_PATH=/auth/callback

ANTHROPIC_API_KEY=sk-ant-placeholder
CLAUDE_CLI_PATH=claude

CLAUDE_COACHING_MODEL=claude-sonnet-4-5
CLAUDE_COMPILE_MODEL=claude-opus-4-7
CLAUDE_UTILITY_MODEL=claude-haiku-4-5-20251001

USER_MONTHLY_INPUT_TOKEN_CAP=2000000
USER_MONTHLY_OUTPUT_TOKEN_CAP=200000

DEFAULT_INSTITUTION_SHORT_NAME=MCC

RESEND_API_KEY=CHANGE_ME
EMAIL_FROM_ADDRESS=thesis@robofox.online
EMAIL_FROM_NAME=Robofox Thesis Studio

R2_ACCOUNT_ID=CHANGE_ME
R2_ACCESS_KEY_ID=CHANGE_ME
R2_SECRET_ACCESS_KEY=CHANGE_ME
R2_BUCKET_NAME=thesis-studio
R2_PUBLIC_URL=CHANGE_ME

CORS_ORIGINS=https://thesis.robofox.online
