# ============================================================
# OWNER-ONLY LIVE ENVIRONMENT — NOT COMPLIANT PRODUCTION, NOT STAGING
# ============================================================
# Copy to the host (chmod 600, outside Git). Generate all secrets ON the host
# with `openssl rand -hex 32`. Every CHANGE_ME must be replaced. The owner has
# explicitly accepted the single-user deviations below.

# --- Application designation ---
# ENV=development is the accepted owner-only designation: it permits the
# dev-grade providers this box actually has (local storage, no scanner) while
# keeping DEBUG=false so no debug auth codes are ever exposed. It is NOT a
# claim of production compliance.
ENV=development
DEBUG=false
LOG_LEVEL=INFO

# --- Release identity (must match the deployed image; do not hand-copy) ---
RELEASE_SHA=CHANGE_ME_DERIVED_ATTESTED_SHA
BUILD_TIME=CHANGE_ME_FROM_RELEASE_WORKFLOW

# --- On-host PostgreSQL 14 (accepted deviation), dedicated v2 database ---
# Reached over host loopback (compose uses host networking) so the shared PG
# server is never reconfigured or restarted. Legacy thesis_studio is left
# untouched as the rollback source.
DATABASE_URL=postgresql+asyncpg://thesis:CHANGE_ME_EXISTING_THESIS_ROLE_PW@localhost:5432/thesis_studio_v2

# --- Auth / sessions (fresh v2-only secret) ---
JWT_SECRET=CHANGE_ME_OPENSSL_RAND_HEX_32
DEFAULT_INSTITUTION_SHORT_NAME=MCC

# --- Owner policy: AI off, billing manual ---
AI_GLOBAL_ENABLED=false
ANTHROPIC_API_KEY=owner-live-placeholder-ai-disabled
BILLING_PROVIDER=manual
BILLING_WEBHOOK_SECRET=CHANGE_ME_OPENSSL_RAND_HEX_32

# --- Storage: local durable v2 path (accepted deviation) ---
STORAGE_BACKEND=local
LOCAL_STORAGE_DIR=/app/var/storage
PRODUCTION_REQUIRE_R2=false

# --- Malware scanning DISABLED by owner-only exception ---
# Only trusted owner-supplied documents may be uploaded. No ClamAV runs and no
# malware scanning is claimed. EICAR is SKIPPED, never recorded as passed.
MALWARE_SCAN_MODE=disabled
PRODUCTION_REQUIRE_MALWARE_SCAN=false

# --- Low-memory pool (1 GB host) — env override; app defaults stay 10/20 ---
DB_POOL_SIZE=2
DB_MAX_OVERFLOW=2

# --- Email: reuse the real Resend config if present and permitted ---
# If set, real sign-in emails are sent (no OTP is ever returned in an API
# response because DEBUG=false). If unset, the app logs the code server-side
# only (never in an API response) — acceptable for a single owner.
RESEND_API_KEY=CHANGE_ME_OR_REUSE_EXISTING
EMAIL_FROM=Robofox Thesis Studio <thesis@robofox.online>

# --- Google Sign-In (owner will OAuth) ---
GOOGLE_CLIENT_ID=CHANGE_ME_OR_REUSE_EXISTING

# --- Frontend / CORS: real domain ---
FRONTEND_URL=https://thesis.robofox.online
FRONTEND_LOGIN_PATH=/auth/verify
CORS_ORIGINS=https://thesis.robofox.online
