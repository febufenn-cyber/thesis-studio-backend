# DEMO ONLY environment — E2.1.Micro co-tenant demo (NOT staging, NOT
# production). Deviations from the staging playbook are deliberate and
# documented in docs/release/staging/E2_DEMO_NOTES.md.
# Copy to the demo host (chmod 600); generate secrets ON the host:
#   openssl rand -hex 32   (JWT_SECRET, and the Postgres password file)

# development designation: the demo intentionally uses dev-grade providers
# (log-based OTP delivery, local storage, no scanner). ENV=staging would fail
# readiness without Resend/ClamAV, and no production secret may be reused here.
ENV=development
DEBUG=false
LOG_LEVEL=INFO

# From the release manifest evidence of the dispatched build (never a branch SHA)
RELEASE_SHA=CHANGE_ME_ATTESTED_APPLICATION_SHA
BUILD_TIME=CHANGE_ME_FROM_RELEASE_WORKFLOW

# Colocated demo Postgres (demo-only exception to the off-host rule).
# Password comes from the file referenced by ROBOFOX_DEMO_PG_PASSWORD_FILE;
# mirror it here. Settings does not mandate TLS outside production; the demo
# runs on an isolated container network without TLS (documented deviation).
DATABASE_URL=postgresql+asyncpg://thesis_demo:CHANGE_ME_SAME_AS_PASSWORD_FILE@postgres:5432/thesis_demo

JWT_SECRET=CHANGE_ME_OPENSSL_RAND_HEX_32
DEFAULT_INSTITUTION_SHORT_NAME=DEMO
ANTHROPIC_API_KEY=demo-placeholder-ai-disabled

# Hard demo policy
AI_GLOBAL_ENABLED=false
BILLING_PROVIDER=manual
BILLING_WEBHOOK_SECRET=CHANGE_ME_OPENSSL_RAND_HEX_32

# Storage: local backend (supported value; no scoped demo R2 credentials exist)
STORAGE_BACKEND=local
PRODUCTION_REQUIRE_R2=false

# Malware scanning: "disabled" is the only supported non-clamav mode
# (app/core/config.py Literal). ClamAV cannot fit in 1 GB. EICAR test is
# therefore SKIPPED for the demo, never recorded as passed.
MALWARE_SCAN_MODE=disabled
PRODUCTION_REQUIRE_MALWARE_SCAN=false

# No RESEND_API_KEY on purpose: dev fallback logs the OTP/magic link instead
# of sending email. No production secret is present in this file.
FRONTEND_URL=http://127.0.0.1:8300
CORS_ORIGINS=http://127.0.0.1:8300
