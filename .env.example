# Robofox Thesis Studio — Environment Variables
# Copy to .env for development. Never commit real credentials.

# ===== Application / release identity =====
ENV=development                    # development | staging | production
DEBUG=true
LOG_LEVEL=INFO
RELEASE_SHA=
BUILD_TIME=
SCHEMA_VERSION=0018
RENDERER_VERSION=phase1-renderer
PROMPT_BUNDLE_VERSION=phase3-prompts
CANONICAL_SCHEMA_VERSION=1

# ===== Database =====
DATABASE_URL=postgresql+asyncpg://thesis:thesis@localhost:5432/thesis_studio

# ===== Authentication and revocable sessions =====
JWT_SECRET=replace_me_with_64_hex_chars_from_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRY_DAYS=30
MAGIC_LINK_EXPIRY_MINUTES=15
SESSION_IDLE_MINUTES=720
SESSION_ABSOLUTE_DAYS=30
SESSION_REAUTH_MINUTES=15
SESSION_COOKIE_NAME=access_token
DEFAULT_INSTITUTION_SHORT_NAME=MCC
GOOGLE_CLIENT_ID=

# ===== Frontend / CORS =====
FRONTEND_URL=http://localhost:8000
FRONTEND_LOGIN_PATH=/auth/verify
CORS_ORIGINS=http://localhost:8000

# ===== AI =====
# The shared Claude CLI is a pilot adapter only. Commercial environments should
# configure a governed provider route and set AI_COMMERCIAL_PROVIDER_READY=true.
ANTHROPIC_API_KEY=test-provider-key-placeholder
CLAUDE_CLI_PATH=claude
CLAUDE_COACHING_MODEL=claude-sonnet-4-6
CLAUDE_COMPILE_MODEL=claude-opus-4-8
CLAUDE_UTILITY_MODEL=claude-haiku-4-5-20251001
AI_GLOBAL_ENABLED=true
AI_COMMERCIAL_PROVIDER_READY=false
AI_PROVIDER_FAILURE_THRESHOLD=5
AI_CIRCUIT_COOLDOWN_SECONDS=300
AI_GLOBAL_EMERGENCY_THROTTLE=false
USER_MONTHLY_INPUT_TOKEN_CAP=2000000
USER_MONTHLY_OUTPUT_TOKEN_CAP=200000

# Example governed provider gateway variables. The provider slug determines the
# endpoint variable name; secrets are referenced as env:NAME or file:/path.
# AI_PROVIDER_PRIMARY_ENDPOINT=https://provider-gateway.example/v1/grounded
# AI_PROVIDER_PRIMARY_TOKEN=replace_me

# ===== Durable worker queues =====
JOB_LEASE_SECONDS=120
JOB_HEARTBEAT_SECONDS=20
WORKER_QUEUE=general
WORKER_ID=

# ===== Billing =====
BILLING_PROVIDER=manual
BILLING_WEBHOOK_SECRET=
BILLING_WEBHOOK_TOLERANCE_SECONDS=300
BILLING_GRACE_DAYS=7

# ===== Email =====
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=thesis@robofox.online
EMAIL_FROM_NAME=Robofox Thesis Studio

# ===== Storage =====
STORAGE_BACKEND=auto               # development may use local; release requires r2
LOCAL_STORAGE_DIR=var/storage
PRODUCTION_REQUIRE_R2=true
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=thesis-studio
R2_PUBLIC_URL=

# ===== Malware scanning =====
# Development may use disabled. Staging and production release validation require clamav.
MALWARE_SCAN_MODE=disabled         # disabled | clamav
PRODUCTION_REQUIRE_MALWARE_SCAN=true
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_SECONDS=30
# Compose release also requires an immutable image reference:
# CLAMAV_IMAGE=clamav/clamav@sha256:...

# ===== Privacy / support =====
SUPPORT_ACCESS_DEFAULT_MINUTES=60
DELETION_GRACE_DAYS=30
PRIVACY_HASH_PEPPER=

# Production environment verification also requires:
# BACKUP_EVIDENCE_PATH=/run/secrets/latest-backup-evidence.json
