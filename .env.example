# Robofox Thesis Studio — Environment Variables
# Copy this file to .env and fill in actual values.
# DO NOT commit .env to git (already in .gitignore).

# ===== Application =====
ENV=development                                 # development | staging | production
DEBUG=true                                      # set to false in production
LOG_LEVEL=INFO

# ===== Database =====
# Local development: docker-compose up postgres
# Production: managed Postgres on Oracle VM
DATABASE_URL=postgresql+asyncpg://thesis:thesis@localhost:5432/thesis_studio

# ===== Authentication =====
# Generate with: openssl rand -hex 32
JWT_SECRET=replace_me_with_64_hex_chars_from_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRY_DAYS=30

# Magic-link token expiry (in minutes)
MAGIC_LINK_EXPIRY_MINUTES=15

# Comma-separated list of allowed institutional email domains.
# Used to gate signup. Anything else is rejected.
ALLOWED_EMAIL_DOMAINS=mcc.edu.in,students.mcc.edu.in

# ===== Frontend =====
FRONTEND_URL=http://localhost:3000              # Next.js app URL
FRONTEND_LOGIN_PATH=/auth/callback              # where magic links redirect

# ===== Anthropic Claude =====
# From console.anthropic.com — use the institutional grant key.
ANTHROPIC_API_KEY=sk-ant-xxxx

# Models — only change if Anthropic releases new ones.
CLAUDE_COACHING_MODEL=claude-sonnet-4-5
CLAUDE_COMPILE_MODEL=claude-opus-4-7
CLAUDE_UTILITY_MODEL=claude-haiku-4-5-20251001

# Per-user monthly token caps (input + output).
USER_MONTHLY_INPUT_TOKEN_CAP=2000000
USER_MONTHLY_OUTPUT_TOKEN_CAP=200000

# ===== Email (Resend) =====
RESEND_API_KEY=re_xxxx
EMAIL_FROM_ADDRESS=thesis@robofox.online
EMAIL_FROM_NAME=Robofox Thesis Studio

# ===== Cloudflare R2 =====
# https://dash.cloudflare.com → R2 → API Tokens
R2_ACCOUNT_ID=xxxx
R2_ACCESS_KEY_ID=xxxx
R2_SECRET_ACCESS_KEY=xxxx
R2_BUCKET_NAME=thesis-studio
R2_PUBLIC_URL=https://thesis-studio.r2.dev    # used for download URLs

# ===== CORS =====
# Comma-separated list of allowed origins for CORS.
CORS_ORIGINS=http://localhost:3000,https://thesis.robofox.online
