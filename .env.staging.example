# Robofox Thesis Studio — STAGING environment template
# Copy to ${STAGING_ENV_PATH} on the staging host (chmod 600). Never commit the
# real file. Every CHANGE_ME must be replaced; scripts/verify_phase5_environment.py
# --target staging must pass before any deploy.

# ===== Application / immutable release identity =====
ENV=staging
DEBUG=false
LOG_LEVEL=INFO
RELEASE_SHA=b2c9c624cd6b6faffe4f9585ac7f4580631abd82
BUILD_TIME=CHANGE_ME_RFC3339_FROM_RELEASE_WORKFLOW
SCHEMA_VERSION=0018
RENDERER_VERSION=phase1-renderer
PROMPT_BUNDLE_VERSION=phase3-prompts
# Must match app/canonical/model.py (documents are stamped 3). Leave unset to
# inherit the code default, or keep in lockstep with the model constant.
CANONICAL_SCHEMA_VERSION=3

# ===== Immutable images (digest-pinned) =====
ROBOFOX_IMAGE=ghcr.io/febufenn-cyber/thesis-studio-backend:b2c9c624cd6b6faffe4f9585ac7f4580631abd82
CLAMAV_IMAGE=clamav/clamav:1.4.5@sha256:86c2a50372da8522186cc8f68e23ebebe9782c7eac21439a6fece9e1a867d038

# ===== Isolated PostgreSQL (separate host/managed; TLS mandatory) =====
# verify_phase5_environment rejects localhost/127.0.0.1/postgres/db hosts and
# requires ssl=/sslmode= in the URL.
DATABASE_URL=postgresql+asyncpg://thesis_staging:CHANGE_ME@CHANGE_ME_DB_HOST:5432/thesis_staging?ssl=require

# ===== Authentication / revocable sessions =====
JWT_SECRET=CHANGE_ME_RUN_OPENSSL_RAND_HEX_32
JWT_ALGORITHM=HS256
JWT_EXPIRY_DAYS=30
MAGIC_LINK_EXPIRY_MINUTES=15
SESSION_IDLE_MINUTES=720
SESSION_ABSOLUTE_DAYS=30
SESSION_REAUTH_MINUTES=15
SESSION_COOKIE_NAME=access_token
DEFAULT_INSTITUTION_SHORT_NAME=STAGE
GOOGLE_CLIENT_ID=

# ===== Frontend / CORS (staging hostnames only) =====
FRONTEND_URL=https://thesis-staging.robofox.online
FRONTEND_LOGIN_PATH=/auth/verify
CORS_ORIGINS=https://thesis-staging.robofox.online

# ===== AI — deterministic degraded mode (decision 2026-07-12) =====
# First staging acceptance proves editor/collaboration/ingest/verify/preview/
# export/storage/sessions/queues/recovery WITHOUT any AI provider. The shared
# Claude CLI/OAuth session must never be a staging dependency. A commercial
# provider arrives later as a separate canary change (docs/release/AI_CANARY_BLOCKER.md).
AI_GLOBAL_ENABLED=false
# NOTE: "AI_COMMERCIAL_PROVIDER_READY" has no code binding in this release;
# AI_GLOBAL_ENABLED=false is the enforced kill switch (app/ai/settings.py).
ANTHROPIC_API_KEY=staging-placeholder-not-used-when-ai-disabled

# ===== Billing — manual institutional mode (decision 2026-07-12) =====
# Entitlement grants, quotas and grace behavior are exercised without payments.
# Sandbox provider integration is a separate post-staging task
# (docs/release/BILLING_SANDBOX_BLOCKER.md).
BILLING_PROVIDER=manual
BILLING_WEBHOOK_SECRET=CHANGE_ME_32CHARS_EVEN_IN_MANUAL_MODE

# ===== Object storage — dedicated staging R2 bucket, least-privilege =====
STORAGE_BACKEND=r2
R2_ACCOUNT_ID=CHANGE_ME
R2_ACCESS_KEY_ID=CHANGE_ME_STAGING_ONLY_TOKEN
R2_SECRET_ACCESS_KEY=CHANGE_ME_STAGING_ONLY_TOKEN
R2_BUCKET_NAME=thesis-staging

# ===== Malware scanning (internal ClamAV from compose) =====
MALWARE_SCAN_MODE=clamav
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
PRODUCTION_REQUIRE_MALWARE_SCAN=true

# ===== Email (staging-safe recipient policy applies) =====
RESEND_API_KEY=CHANGE_ME_STAGING_KEY
EMAIL_FROM=Robofox Thesis Studio Staging <staging@robofox.online>

# ===== Privacy / logging =====
PRIVACY_HASH_PEPPER=CHANGE_ME_RUN_OPENSSL_RAND_HEX_32

# ===== Worker topology (compose.phase5.yml) =====
WEB_A_PORT=8101
WEB_B_PORT=8102
JOB_LEASE_SECONDS=120
JOB_HEARTBEAT_SECONDS=20
